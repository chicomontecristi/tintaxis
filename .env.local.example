# ─── THE SCRIPTORIUM — ENVIRONMENT VARIABLES ─────────────────────────────────
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to git.

# ─── SIGNAL INK — Email delivery for reader questions ─────────────────────────
# Get a free key at https://resend.com → Dashboard → API Keys → Create API Key
# Free tier: 3,000 emails/month, 100/day — more than enough for Phase 1.
RESEND_API_KEY=re_your_api_key_here

# Where Signal Ink questions are delivered (your email as the author)
SIGNAL_TO_EMAIL=chico@tintaxis.com

# The "from" address in the email.
# Use "onboarding@resend.dev" on the free tier — works immediately, no domain needed.
# Phase 2: swap for a verified domain, e.g. signal@scriptorium.com
SIGNAL_FROM_EMAIL=onboarding@resend.dev

# ─── RESEND SETUP — 5 minutes ─────────────────────────────────────────────────
# 1. Go to https://resend.com → Sign up (free, no credit card)
# 2. Dashboard → API Keys → Create API Key → copy it as RESEND_API_KEY above
# 3. Vercel: Project → Settings → Environment Variables → add all 3 vars
# 4. Redeploy (Vercel auto-deploys when env vars change)
# 5. Test: Select text in Chapter 1 → Signal Ink → send a question
#    → check chico@tintaxis.com for the styled dark-mode email
# ─────────────────────────────────────────────────────────────────────────────

# ─── PHASE 2 (not needed yet) ─────────────────────────────────────────────────
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
# CLERK_SECRET_KEY=
# DATABASE_URL=
# REDIS_URL=
# NEXT_PUBLIC_SANITY_PROJECT_ID=
# SANITY_API_TOKEN=
# STRIPE_SECRET_KEY=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
